const text="Student • Web Developer • UI/UX Enthusiast • Graphic Designer • Future Software Engineer";

let i=0;

function typing(){

if(i<text.length){

document.getElementById("typing").innerHTML+=text.charAt(i);

i++;

setTimeout(typing,45);

}

}

